# Приветственное сообщение /start
WELCOME_TEXT=Добро пожаловать! Этот бот помогает записаться на авторскую экскурсию и узнать больше о проекте.
# Картинка: укажите URL или локальный файл (достаточно одного варианта)
WELCOME_IMAGE_URL=
